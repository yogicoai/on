# ── Vercel 환경변수 (Project Settings → Environment Variables) ──
# MongoDB는 Atlas/공개 호스트여야 Vercel에서 접속됩니다.

# 분석 캐시 DB (없으면 CAFE24_TOKEN_URI / MONGODB_URI 순으로 사용)
MONGODB_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net
# ONLINEDATA_URI=
# ONLINEDATA_DB=onlinedata

# Cafe24 토큰(yogiChat가 소유한 공유 Mongo에서 읽기전용 재사용)
CAFE24_MALL_ID=yogibo
CAFE24_API_VERSION=2025-03-01
CAFE24_TOKEN_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net
CAFE24_TOKEN_DB=yogichat
CAFE24_TOKEN_COLLECTION=tokens

# 네이버 커머스(스마트스토어) — 동기화는 로컬에서만 쓰므로 읽기전용 배포엔 선택
NAVER_COMMERCE_CLIENT_ID=
NAVER_COMMERCE_CLIENT_SECRET=

# 읽기 전용 배포: 수집/동기화/설정변경 비활성화 (Vercel에서 1로 설정 권장)
READ_ONLY=1

# ── 매일 자동 동기화 스케줄러 (항상 켜진 호스트 전용 — ychat 등) ──
# Vercel/READ_ONLY=1 에서는 자동 비활성. 상시 `node server.js` 호스트에서만 1로.
# ENABLE_DAILY_SYNC=1     # 매일 00:00(로컬=KST) 최근 1주일 적재+워밍 자동 실행
# DAILY_SYNC_DAYS=7       # 자동 동기화 적재 일수(기본 7)
# DAILY_SYNC_ON_BOOT=1    # 서버 기동 직후 1회 즉시 동기화(선택)
